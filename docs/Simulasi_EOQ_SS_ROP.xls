    <Cell ss:StyleID="Label"><Data ss:Type="String">Hari 13</Data></Cell>
    <Cell ss:StyleID="InputCell"><Data ss:Type="Number">0</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">Hari 14</Data></Cell>
    <Cell ss:StyleID="InputCell"><Data ss:Type="Number">0</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">Hari 15</Data></Cell>
    <Cell ss:StyleID="InputCell"><Data ss:Type="Number">0</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">Hari 16</Data></Cell>
    <Cell ss:StyleID="InputCell"><Data ss:Type="Number">0</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">Hari 17</Data></Cell>
    <Cell ss:StyleID="InputCell"><Data ss:Type="Number">0</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">Hari 18</Data></Cell>
    <Cell ss:StyleID="InputCell"><Data ss:Type="Number">0</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">Hari 19</Data></Cell>
    <Cell ss:StyleID="InputCell"><Data ss:Type="Number">0</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">Hari 20</Data></Cell>
    <Cell ss:StyleID="InputCell"><Data ss:Type="Number">0</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">Hari 21</Data></Cell>
    <Cell ss:StyleID="InputCell"><Data ss:Type="Number">0</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">Hari 22</Data></Cell>
    <Cell ss:StyleID="InputCell"><Data ss:Type="Number">0</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">Hari 23</Data></Cell>
    <Cell ss:StyleID="InputCell"><Data ss:Type="Number">0</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">Hari 24</Data></Cell>
    <Cell ss:StyleID="InputCell"><Data ss:Type="Number">0</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">Hari 25</Data></Cell>
    <Cell ss:StyleID="InputCell"><Data ss:Type="Number">0</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">Hari 26</Data></Cell>
    <Cell ss:StyleID="InputCell"><Data ss:Type="Number">0</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">Hari 27</Data></Cell>
    <Cell ss:StyleID="InputCell"><Data ss:Type="Number">0</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">Hari 28</Data></Cell>
    <Cell ss:StyleID="InputCell"><Data ss:Type="Number">0</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">Hari 29</Data></Cell>
    <Cell ss:StyleID="InputCell"><Data ss:Type="Number">0</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">Hari 30</Data></Cell>
    <Cell ss:StyleID="InputCell"><Data ss:Type="Number">0</Data></Cell>
   </Row>
   <Row/>

   <!-- KALKULASI OTOMATIS -->
   <Row>
    <Cell ss:StyleID="SectionTitle"><Data ss:Type="String">KALKULASI OTOMATIS</Data></Cell>
    <Cell ss:StyleID="SectionTitle"><Data ss:Type="String">Hasil</Data></Cell>
    <Cell ss:StyleID="SectionTitle"><Data ss:Type="String">Satuan</Data></Cell>
    <Cell ss:StyleID="SectionTitle"><Data ss:Type="String">Formula Excel</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">Jumlah Hari Aktif</Data></Cell>
    <Cell ss:StyleID="ResultCell" ss:Formula="=COUNTIF(R[-30]C:R[-1]C,&quot;&gt;0&quot;)"><Data ss:Type="Number">10</Data></Cell>
    <Cell><Data ss:Type="String">hari</Data></Cell>
    <Cell ss:StyleID="Note"><Data ss:Type="String">=COUNTIF(B12:B41,"&gt;0")</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">Total Penjualan</Data></Cell>
    <Cell ss:StyleID="ResultCell" ss:Formula="=SUM(R[-31]C:R[-2]C)"><Data ss:Type="Number">60</Data></Cell>
    <Cell><Data ss:Type="String">unit</Data></Cell>
    <Cell ss:StyleID="Note"><Data ss:Type="String">=SUM(B12:B41)</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">Permintaan Rata-rata/hari</Data></Cell>
    <Cell ss:StyleID="ResultCell" ss:Formula="=IF(R[-2]C=0,0,R[-1]C/R[-2]C)"><Data ss:Type="Number">6</Data></Cell>
    <Cell><Data ss:Type="String">unit/hari</Data></Cell>
    <Cell ss:StyleID="Note"><Data ss:Type="String">=IF(B43=0,0,B44/B43)</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">Permintaan Maks/hari</Data></Cell>
    <Cell ss:StyleID="ResultCell" ss:Formula="=MAX(R[-34]C:R[-5]C)"><Data ss:Type="Number">10</Data></Cell>
    <Cell><Data ss:Type="String">unit/hari</Data></Cell>
    <Cell ss:StyleID="Note"><Data ss:Type="String">=MAX(B12:B41)</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">Demand Tahunan (D)</Data></Cell>
    <Cell ss:StyleID="ResultCell" ss:Formula="=R[-2]C*365"><Data ss:Type="Number">2190</Data></Cell>
    <Cell><Data ss:Type="String">unit/tahun</Data></Cell>
    <Cell ss:StyleID="Note"><Data ss:Type="String">=B45*365</Data></Cell>
   </Row>
   <Row/>

   <!-- HASIL -->
   <Row>
    <Cell ss:StyleID="SectionTitle"><Data ss:Type="String">HASIL PERHITUNGAN</Data></Cell>
    <Cell ss:StyleID="SectionTitle"><Data ss:Type="String">Hasil</Data></Cell>
    <Cell ss:StyleID="SectionTitle"><Data ss:Type="String">Satuan</Data></Cell>
    <Cell ss:StyleID="SectionTitle"><Data ss:Type="String">Formula Excel</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">EOQ (Economic Order Quantity)</Data></Cell>
    <Cell ss:StyleID="ResultHighlight" ss:Formula="=IF(OR(R[-4]C=0,R8C[-46]=0,R8C[-46]=0),0,ROUNDUP(SQRT((2*R[-4]C*R5C)/(R6C)),0))"><Data ss:Type="Number">210</Data></Cell>
    <Cell><Data ss:Type="String">unit</Data></Cell>
    <Cell ss:StyleID="Note"><Data ss:Type="String">=ROUNDUP(SQRT((2*D*S)/H),0)</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">Safety Stock (SS)</Data></Cell>
    <Cell ss:StyleID="ResultHighlight" ss:Formula="=MAX(0,ROUNDUP((R[-6]C*R8C)-(R[-7]C*R7C),0))"><Data ss:Type="Number">58</Data></Cell>
    <Cell><Data ss:Type="String">unit</Data></Cell>
    <Cell ss:StyleID="Note"><Data ss:Type="String">=(MaxDaily×LT_Max)−(AvgDaily×LT_Avg)</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">ROP (Reorder Point)</Data></Cell>
    <Cell ss:StyleID="ResultHighlight" ss:Formula="=ROUNDUP((R[-8]C*R7C)+R[-1]C,0)"><Data ss:Type="Number">100</Data></Cell>
    <Cell><Data ss:Type="String">unit</Data></Cell>
    <Cell ss:StyleID="Note"><Data ss:Type="String">=(AvgDaily×LT_Avg)+SS</Data></Cell>
   </Row>
   <Row/>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">STATUS REORDER</Data></Cell>
    <Cell ss:StyleID="ResultCell" ss:Formula="=IF(R9C&lt;=R[-2]C,&quot;⚠️ PERLU REORDER&quot;,&quot;✓ STOK AMAN&quot;)"><Data ss:Type="String">⚠️ PERLU REORDER</Data></Cell>
    <Cell/>
    <Cell ss:StyleID="Note"><Data ss:Type="String">=IF(Stok&lt;=ROP,"PERLU REORDER","STOK AMAN")</Data></Cell>
   </Row>
  </Table>
 </Worksheet>

 <!-- ==================== SHEET 3: PANDUAN ==================== -->
 <Worksheet ss:Name="Panduan">
  <Table ss:DefaultColumnWidth="100">
   <Column ss:Index="1" ss:Width="600"/>

   <Row ss:Height="30">
    <Cell ss:StyleID="Title"><Data ss:Type="String">PANDUAN PENGGUNAAN</Data></Cell>
   </Row>
   <Row/>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">1. Cara Menggunakan Simulasi</Data></Cell>
   </Row>
   <Row>
    <Cell><Data ss:Type="String">   - Buka sheet "Dengan Formula" untuk kalkulasi otomatis</Data></Cell>
   </Row>
   <Row>
    <Cell><Data ss:Type="String">   - Isi parameter di bagian kuning: Biaya Pemesanan (S), Biaya Penyimpanan (H), Lead Time Avg, Lead Time Max, Stok</Data></Cell>
   </Row>
   <Row>
    <Cell><Data ss:Type="String">   - Isi data penjualan harian di kolom "Kuantitas" (hari tanpa penjualan biarkan 0)</Data></Cell>
   </Row>
   <Row>
    <Cell><Data ss:Type="String">   - Hasil EOQ, Safety Stock, ROP, dan Status akan terhitung otomatis</Data></Cell>
   </Row>
   <Row/>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">2. Penjelasan Formula</Data></Cell>
   </Row>
   <Row>
    <Cell><Data ss:Type="String">   EOQ = √((2 × D × S) / H)  →  dibulatkan ke atas</Data></Cell>
   </Row>
   <Row>
    <Cell><Data ss:Type="String">   Safety Stock = (Permintaan Maks × Lead Time Maks) − (Permintaan Rata-rata × Lead Time Rata-rata)</Data></Cell>
   </Row>
   <Row>
    <Cell><Data ss:Type="String">   ROP = (Permintaan Rata-rata × Lead Time Rata-rata) + Safety Stock</Data></Cell>
   </Row>
   <Row>
    <Cell><Data ss:Type="String">   Status = Jika Stok ≤ ROP → "Perlu Reorder", Jika Stok > ROP → "Aman"</Data></Cell>
   </Row>
   <Row/>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">3. Keterangan Variabel</Data></Cell>
   </Row>
   <Row>
    <Cell><Data ss:Type="String">   D = Demand Tahunan (proyeksi dari rata-rata harian × 365)</Data></Cell>
   </Row>
   <Row>
    <Cell><Data ss:Type="String">   S = Biaya Pemesanan per pesanan (ordering cost)</Data></Cell>
   </Row>
   <Row>
    <Cell><Data ss:Type="String">   H = Biaya Penyimpanan per unit per tahun (holding cost)</Data></Cell>
   </Row>
   <Row>
    <Cell><Data ss:Type="String">   Lead Time Avg = Rata-rata waktu tunggu pengiriman dari supplier</Data></Cell>
   </Row>
   <Row>
    <Cell><Data ss:Type="String">   Lead Time Max = Waktu tunggu pengiriman paling lama</Data></Cell>
   </Row>
   <Row/>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">4. Tips</Data></Cell>
   </Row>
   <Row>
    <Cell><Data ss:Type="String">   - Gunakan data penjualan minimal 7-30 hari untuk hasil yang lebih akurat</Data></Cell>
   </Row>
   <Row>
    <Cell><Data ss:Type="String">   - Hari tanpa penjualan (nilai 0) TIDAK dihitung sebagai hari aktif</Data></Cell>
   </Row>
   <Row>
    <Cell><Data ss:Type="String">   - Tambah baris penjualan jika data lebih dari 30 hari (sesuaikan range formula)</Data></Cell>
   </Row>
   <Row>
    <Cell><Data ss:Type="String">   - Sheet "Simulasi EOQ-SS-ROP" berisi contoh nilai statis untuk referensi manual</Data></Cell>
   </Row>
  </Table>
 </Worksheet>
</Workbook>
