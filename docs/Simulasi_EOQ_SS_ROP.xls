<?xml version="1.0"?>
<?mso-application progid="Excel.Sheet"?>
<Workbook xmlns="urn:schemas-microsoft-com:office:spreadsheet"
 xmlns:o="urn:schemas-microsoft-com:office:office"
 xmlns:x="urn:schemas-microsoft-com:office:excel"
 xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet">

 <Styles>
  <Style ss:ID="Default" ss:Name="Normal">
   <Alignment ss:Vertical="Center"/>
   <Font ss:FontName="Calibri" ss:Size="11"/>
  </Style>
  <Style ss:ID="Header">
   <Alignment ss:Horizontal="Center" ss:Vertical="Center"/>
   <Font ss:FontName="Calibri" ss:Size="11" ss:Bold="1" ss:Color="#FFFFFF"/>
   <Interior ss:Color="#2B5797" ss:Pattern="Solid"/>
   <Borders>
    <Border ss:Position="Bottom" ss:LineStyle="Continuous" ss:Weight="1"/>
   </Borders>
  </Style>
  <Style ss:ID="SubHeader">
   <Alignment ss:Horizontal="Center" ss:Vertical="Center"/>
   <Font ss:FontName="Calibri" ss:Size="10" ss:Bold="1" ss:Color="#FFFFFF"/>
   <Interior ss:Color="#4472C4" ss:Pattern="Solid"/>
   <Borders>
    <Border ss:Position="Bottom" ss:LineStyle="Continuous" ss:Weight="1"/>
   </Borders>
  </Style>
  <Style ss:ID="Title">
   <Font ss:FontName="Calibri" ss:Size="16" ss:Bold="1" ss:Color="#2B5797"/>
  </Style>
  <Style ss:ID="SectionTitle">
   <Font ss:FontName="Calibri" ss:Size="12" ss:Bold="1" ss:Color="#2B5797"/>
   <Interior ss:Color="#D6E4F0" ss:Pattern="Solid"/>
  </Style>
  <Style ss:ID="InputCell">
   <Interior ss:Color="#FFF2CC" ss:Pattern="Solid"/>
   <Borders>
    <Border ss:Position="Bottom" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#E0E0E0"/>
    <Border ss:Position="Left" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#E0E0E0"/>
    <Border ss:Position="Right" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#E0E0E0"/>
    <Border ss:Position="Top" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#E0E0E0"/>
   </Borders>
  </Style>
  <Style ss:ID="ResultCell">
   <Font ss:FontName="Calibri" ss:Size="11" ss:Bold="1"/>
   <Interior ss:Color="#E2EFDA" ss:Pattern="Solid"/>
   <Borders>
    <Border ss:Position="Bottom" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#E0E0E0"/>
    <Border ss:Position="Left" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#E0E0E0"/>
    <Border ss:Position="Right" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#E0E0E0"/>
    <Border ss:Position="Top" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#E0E0E0"/>
   </Borders>
  </Style>
  <Style ss:ID="ResultHighlight">
   <Font ss:FontName="Calibri" ss:Size="14" ss:Bold="1" ss:Color="#2B5797"/>
   <Interior ss:Color="#E2EFDA" ss:Pattern="Solid"/>
   <Borders>
    <Border ss:Position="Bottom" ss:LineStyle="Continuous" ss:Weight="2" ss:Color="#2B5797"/>
    <Border ss:Position="Left" ss:LineStyle="Continuous" ss:Weight="2" ss:Color="#2B5797"/>
    <Border ss:Position="Right" ss:LineStyle="Continuous" ss:Weight="2" ss:Color="#2B5797"/>
    <Border ss:Position="Top" ss:LineStyle="Continuous" ss:Weight="2" ss:Color="#2B5797"/>
   </Borders>
  </Style>
  <Style ss:ID="StatusReorder">
   <Font ss:FontName="Calibri" ss:Size="11" ss:Bold="1" ss:Color="#CC0000"/>
   <Interior ss:Color="#FDE9D9" ss:Pattern="Solid"/>
  </Style>
  <Style ss:ID="StatusAman">
   <Font ss:FontName="Calibri" ss:Size="11" ss:Bold="1" ss:Color="#006600"/>
   <Interior ss:Color="#E2EFDA" ss:Pattern="Solid"/>
  </Style>
  <Style ss:ID="Label">
   <Font ss:FontName="Calibri" ss:Size="11" ss:Bold="1"/>
  </Style>
  <Style ss:ID="Note">
   <Font ss:FontName="Calibri" ss:Size="9" ss:Italic="1" ss:Color="#666666"/>
  </Style>
 </Styles>

 <!-- ==================== SHEET 1: SIMULASI ==================== -->
 <Worksheet ss:Name="Simulasi EOQ-SS-ROP">
  <Table ss:DefaultColumnWidth="100">
   <Column ss:Index="1" ss:Width="200"/>
   <Column ss:Index="2" ss:Width="150"/>
   <Column ss:Index="3" ss:Width="120"/>
   <Column ss:Index="4" ss:Width="200"/>

   <!-- JUDUL -->
   <Row ss:Height="30">
    <Cell ss:StyleID="Title"><Data ss:Type="String">SIMULASI EOQ, SAFETY STOCK &amp; ROP</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="Note"><Data ss:Type="String">Isi sel berwarna kuning untuk menghitung otomatis. Hasil muncul di sel hijau.</Data></Cell>
   </Row>
   <Row/>

   <!-- SECTION: PARAMETER INPUT -->
   <Row>
    <Cell ss:StyleID="SectionTitle"><Data ss:Type="String">PARAMETER INPUT</Data></Cell>
    <Cell ss:StyleID="SectionTitle"><Data ss:Type="String">Nilai</Data></Cell>
    <Cell ss:StyleID="SectionTitle"><Data ss:Type="String">Satuan</Data></Cell>
    <Cell ss:StyleID="SectionTitle"><Data ss:Type="String">Keterangan</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">Biaya Pemesanan (S)</Data></Cell>
    <Cell ss:StyleID="InputCell"><Data ss:Type="Number">50000</Data></Cell>
    <Cell><Data ss:Type="String">Rp / pesanan</Data></Cell>
    <Cell ss:StyleID="Note"><Data ss:Type="String">Biaya setiap kali memesan</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">Biaya Penyimpanan (H)</Data></Cell>
    <Cell ss:StyleID="InputCell"><Data ss:Type="Number">5000</Data></Cell>
    <Cell><Data ss:Type="String">Rp / unit / tahun</Data></Cell>
    <Cell ss:StyleID="Note"><Data ss:Type="String">Biaya simpan per unit per tahun</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">Lead Time Rata-rata</Data></Cell>
    <Cell ss:StyleID="InputCell"><Data ss:Type="Number">7</Data></Cell>
    <Cell><Data ss:Type="String">hari</Data></Cell>
    <Cell ss:StyleID="Note"><Data ss:Type="String">Rata-rata waktu tunggu pengiriman</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">Lead Time Maksimal</Data></Cell>
    <Cell ss:StyleID="InputCell"><Data ss:Type="Number">10</Data></Cell>
    <Cell><Data ss:Type="String">hari</Data></Cell>
    <Cell ss:StyleID="Note"><Data ss:Type="String">Waktu tunggu paling lama</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">Stok Saat Ini</Data></Cell>
    <Cell ss:StyleID="InputCell"><Data ss:Type="Number">50</Data></Cell>
    <Cell><Data ss:Type="String">unit</Data></Cell>
    <Cell ss:StyleID="Note"><Data ss:Type="String">Stok di gudang saat ini</Data></Cell>
   </Row>
   <Row/>

   <!-- SECTION: DATA PENJUALAN -->
   <Row>
    <Cell ss:StyleID="SectionTitle"><Data ss:Type="String">DATA PENJUALAN HARIAN</Data></Cell>
    <Cell ss:StyleID="SectionTitle"><Data ss:Type="String">Kuantitas</Data></Cell>
    <Cell ss:StyleID="SectionTitle"/>
    <Cell ss:StyleID="SectionTitle"><Data ss:Type="String">Tambahkan baris sesuai kebutuhan</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">Hari 1</Data></Cell>
    <Cell ss:StyleID="InputCell"><Data ss:Type="Number">5</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">Hari 2</Data></Cell>
    <Cell ss:StyleID="InputCell"><Data ss:Type="Number">8</Data></Cell>
   </Row>
