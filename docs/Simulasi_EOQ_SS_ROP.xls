   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">Hari 22</Data></Cell>
    <Cell ss:StyleID="InputCell"><Data ss:Type="Number">0</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">Hari 23</Data></Cell>
