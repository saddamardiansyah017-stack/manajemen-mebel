   </Row>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">Hari 25</Data></Cell>
    <Cell ss:StyleID="InputCell"><Data ss:Type="Number">0</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">Hari 26</Data></Cell>
    <Cell ss:StyleID="InputCell"><Data ss:Type="Number">0</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">Hari 27</Data></Cell>
    <Cell ss:StyleID="InputCell"><Data ss:Type="Number">0</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">Hari 28</Data></Cell>
    <Cell ss:StyleID="InputCell"><Data ss:Type="Number">0</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">Hari 29</Data></Cell>
    <Cell ss:StyleID="InputCell"><Data ss:Type="Number">0</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">Hari 30</Data></Cell>
    <Cell ss:StyleID="InputCell"><Data ss:Type="Number">0</Data></Cell>
   </Row>
   <Row/>

   <!-- SECTION: KALKULASI OTOMATIS -->
   <Row>
    <Cell ss:StyleID="SectionTitle"><Data ss:Type="String">KALKULASI OTOMATIS</Data></Cell>
    <Cell ss:StyleID="SectionTitle"><Data ss:Type="String">Hasil</Data></Cell>
    <Cell ss:StyleID="SectionTitle"><Data ss:Type="String">Satuan</Data></Cell>
    <Cell ss:StyleID="SectionTitle"><Data ss:Type="String">Formula</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">Jumlah Hari Aktif (ada penjualan)</Data></Cell>
    <Cell ss:StyleID="ResultCell"><Data ss:Type="Number">10</Data><NamedCell ss:Name="JumlahHariAktif"/></Cell>
    <Cell><Data ss:Type="String">hari</Data></Cell>
    <Cell ss:StyleID="Note"><Data ss:Type="String">COUNTIF(B14:B43,"&gt;0")</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">Total Penjualan</Data></Cell>
    <Cell ss:StyleID="ResultCell"><Data ss:Type="Number">60</Data><NamedCell ss:Name="TotalPenjualan"/></Cell>
    <Cell><Data ss:Type="String">unit</Data></Cell>
    <Cell ss:StyleID="Note"><Data ss:Type="String">SUM(B14:B43)</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">Permintaan Rata-rata/hari</Data></Cell>
    <Cell ss:StyleID="ResultCell"><Data ss:Type="Number">6</Data><NamedCell ss:Name="AvgDaily"/></Cell>
    <Cell><Data ss:Type="String">unit/hari</Data></Cell>
    <Cell ss:StyleID="Note"><Data ss:Type="String">Total Penjualan / Jumlah Hari Aktif</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">Permintaan Maks/hari</Data></Cell>
    <Cell ss:StyleID="ResultCell"><Data ss:Type="Number">10</Data><NamedCell ss:Name="MaxDaily"/></Cell>
    <Cell><Data ss:Type="String">unit/hari</Data></Cell>
    <Cell ss:StyleID="Note"><Data ss:Type="String">MAX(B14:B43)</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">Demand Tahunan (D) — Proyeksi</Data></Cell>
    <Cell ss:StyleID="ResultCell"><Data ss:Type="Number">2190</Data><NamedCell ss:Name="DemandTahunan"/></Cell>
    <Cell><Data ss:Type="String">unit/tahun</Data></Cell>
    <Cell ss:StyleID="Note"><Data ss:Type="String">Avg Daily × 365</Data></Cell>
   </Row>
   <Row/>

   <!-- SECTION: HASIL EOQ -->
   <Row>
    <Cell ss:StyleID="SectionTitle"><Data ss:Type="String">HASIL PERHITUNGAN</Data></Cell>
    <Cell ss:StyleID="SectionTitle"><Data ss:Type="String">Hasil</Data></Cell>
    <Cell ss:StyleID="SectionTitle"><Data ss:Type="String">Satuan</Data></Cell>
    <Cell ss:StyleID="SectionTitle"><Data ss:Type="String">Formula</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">EOQ (Economic Order Quantity)</Data></Cell>
    <Cell ss:StyleID="ResultHighlight"><Data ss:Type="Number">210</Data><NamedCell ss:Name="EOQ"/></Cell>
    <Cell><Data ss:Type="String">unit</Data></Cell>
    <Cell ss:StyleID="Note"><Data ss:Type="String">ROUNDUP(SQRT((2 × D × S) / H), 0)</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">Safety Stock (SS)</Data></Cell>
    <Cell ss:StyleID="ResultHighlight"><Data ss:Type="Number">58</Data><NamedCell ss:Name="SafetyStock"/></Cell>
    <Cell><Data ss:Type="String">unit</Data></Cell>
    <Cell ss:StyleID="Note"><Data ss:Type="String">(MaxDaily × LT_Max) − (AvgDaily × LT_Avg)</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">ROP (Reorder Point)</Data></Cell>
    <Cell ss:StyleID="ResultHighlight"><Data ss:Type="Number">100</Data><NamedCell ss:Name="ROP"/></Cell>
    <Cell><Data ss:Type="String">unit</Data></Cell>
    <Cell ss:StyleID="Note"><Data ss:Type="String">(AvgDaily × LT_Avg) + Safety Stock</Data></Cell>
   </Row>
   <Row/>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">STATUS REORDER</Data></Cell>
    <Cell ss:StyleID="StatusReorder"><Data ss:Type="String">⚠️ PERLU REORDER</Data></Cell>
    <Cell/>
    <Cell ss:StyleID="Note"><Data ss:Type="String">Stok (50) ≤ ROP (100) → Perlu Reorder</Data></Cell>
   </Row>
   <Row/>
   <Row>
    <Cell ss:StyleID="Note"><Data ss:Type="String">📌 Catatan: Buka file ini di Microsoft Excel atau LibreOffice Calc.</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="Note"><Data ss:Type="String">    Ubah nilai di sel kuning, lalu hitung ulang secara manual atau gunakan sheet "Dengan Formula".</Data></Cell>
   </Row>
  </Table>
 </Worksheet>

 <!-- ==================== SHEET 2: DENGAN FORMULA ==================== -->
