   </Row>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">Hari 14</Data></Cell>
    <Cell ss:StyleID="InputCell"><Data ss:Type="Number">0</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="Label"><Data ss:Type="String">Hari 15</Data></Cell>
